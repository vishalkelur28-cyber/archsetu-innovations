{
  "name": "@archsetu/cli",
  "version": "0.1.0",
  "description": "ArchSetu CLI - analyze any local codebase from the terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishalkelur28-cyber/archsetu-innovations.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/vishalkelur28-cyber/archsetu-innovations#readme",
  "bugs": "https://github.com/vishalkelur28-cyber/archsetu-innovations/issues",
  "author": "ArchSetu",
  "keywords": [
    "static-analysis",
    "cli",
    "code-analysis",
    "codebase-health"
  ],
  "bin": {
