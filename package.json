{
  "name": "archsetu-oss",
  "version": "0.1.0",
  "private": true,
  "description": "ArchSetu open-source analysis engine and CLI (monorepo root)",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
